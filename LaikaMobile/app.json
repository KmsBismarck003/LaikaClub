{
  "expo": {
    "name": "LaikaMobile",
    "slug": "LaikaMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Laika Club necesita usar Face ID para proteger el acceso a tus boletos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ],
      "package": "com.anonymous.LaikaMobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
